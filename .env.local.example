# Copie para .env.local e preencha. Nunca commite valores reais.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_APP_URL=https://crm.guilds.com.br

# Server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# CRON_SECRET: gere com `openssl rand -hex 32`
CRON_SECRET=GERAR_VALOR_ALEATORIO_DE_32_BYTES

# Camada de IA
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Observabilidade
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_AUTH_TOKEN=sntrys_...

# Email (Brevo) - onboarding e notificacoes
BREVO_API_KEY=xkeysib-...
FROM_EMAIL=comercial@guilds.com.br
FROM_NAME=Guilds Comercial

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
# Price metered "Guilds AI Overage" — cobra R$0,30 por unit, weighted via lib/stripe.ts
STRIPE_PRICE_AI_OVERAGE=price_...

# Multi-currency (opcional — se não definido, usa env legado acima como BRL)
# Padrão: STRIPE_PRICE_{PLAN}_{CURRENCY}
STRIPE_PRICE_STARTER_USD=price_...
STRIPE_PRICE_GROWTH_USD=price_...
STRIPE_PRICE_SCALE_USD=price_...
STRIPE_PRICE_AI_OVERAGE_USD=price_...
# STRIPE_PRICE_*_EUR=price_...   # quando criar prices em EUR

# Web Push notifications — gerar via `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BE1...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:contato@suaempresa.com
